# Module 5 — Environment Variables
# Copy this file to .env and fill in your values before running demos.
# Never commit .env to version control.

# ── AWS ──────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1

# ── Mock Mode ─────────────────────────────────────────────────────────────────
# Set to true to use mock tool data (no partner API keys needed).
# LLM calls via Bedrock are always live regardless of this setting.
AGENT_MOCK_DOMAIN=true

# ── Algolia (Customer Domain) ─────────────────────────────────────────────────
# Sign up free at algolia.com — use the Search API key (not Admin/Write)
ALGOLIA_APP_ID=<your-algolia-app-id>
ALGOLIA_API_KEY=<your-algolia-search-api-key>

# ── Deepgram (Voice Domain) ───────────────────────────────────────────────────
# Sign up free at console.deepgram.com — $200 free credit, no card required
DEEPGRAM_API_KEY=<your-deepgram-api-key>

# ── Mapbox (Geospatial Domain) ────────────────────────────────────────────────
# Sign up free at account.mapbox.com — default public token works for dev
MAPBOX_ACCESS_TOKEN=<your-mapbox-access-token>

# ── Amazon Location Service (Geospatial Domain) ───────────────────────────────
# Create these resources in your AWS account (us-east-1 recommended):
#   aws location create-place-index --index-name devops-place-index --data-source Esri --pricing-plan RequestBasedUsage --region us-east-1
#   aws location create-route-calculator --calculator-name devops-route-calculator --data-source Esri --pricing-plan RequestBasedUsage --region us-east-1
AGENT_LOCATION_INDEX_NAME=devops-place-index
AGENT_LOCATION_ROUTE_CALCULATOR=devops-route-calculator

# ── Amazon Lex V2 (Customer Domain — optional, mock handles it by default) ────
# AGENT_LEX_BOT_ID=<your-lex-bot-id>

# ── Amazon Personalize (Customer Domain — optional, mock handles it by default)
# AGENT_PERSONALIZE_CAMPAIGN_ARN=<your-campaign-arn>

# ── Amazon Connect (Customer Domain — optional, mock handles it by default) ───
# AGENT_CONNECT_INSTANCE_ID=<your-connect-instance-id>
# AGENT_CONNECT_CONTACT_FLOW_ID=<your-contact-flow-id>

# ── Module 7: Agent Memory Systems ───────────────────────────────────────────
# Set to true to use mock memory backends (no Redis/MongoDB/Neo4j credentials
# needed). LLM calls via Bedrock are always live regardless of this setting.
AGENT_MOCK_MEMORY=true

# TLS verification is secure by default and uses the bundled `certifi` CA bundle,
# so MongoDB Atlas / Neo4j Aura certificates validate out of the box — including
# on macOS Python builds with an empty system trust store. You normally never need
# the override below. Set it to true ONLY as a last-resort local-dev workaround to
# skip certificate verification. Never enable it in production.
# MODULE7_INSECURE_TLS=true

# ── Redis Cloud (Session Memory — LangGraph checkpointer) ────────────────────
# Sign up free at redis.io/cloud — free database, no credit card required.
REDIS_HOST=<your-redis-host>.db.redis.io
REDIS_PORT=<your-redis-port>
REDIS_USERNAME=default
REDIS_PASSWORD=<your-redis-password>
# REDIS_SESSION_TTL=86400

# ── MongoDB Atlas (Long-Term Semantic Memory — Vector Search) ────────────────
# Sign up free at mongodb.com/atlas — M0 free cluster. Create a Vector Search
# index named 'vector_index' (see module7/README.md for the definition).
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<app>
MONGODB_DATABASE=agent_memory
MONGODB_COLLECTION=memories
MONGODB_VECTOR_INDEX=vector_index

# ── Neo4j Aura (Graph Relationship Memory) ───────────────────────────────────
# Sign up free at neo4j.com/cloud — AuraDB Free, no credit card required.
# AWS Marketplace: prodview-xd42uzj2v7dae
NEO4J_URI=<your-neo4j-aura-uri>
NEO4J_USERNAME=<your-neo4j-username>
NEO4J_PASSWORD=<your-neo4j-password>

# ── PII Guardrail (optional production layer) ────────────────────────────────
# Deterministic redaction of emails/phones/AWS keys is always on. Set a Bedrock
# Guardrail ID to add ML-based PII detection (e.g. names) on memory writes.
# MODULE7_BEDROCK_GUARDRAIL_ID=<your-bedrock-guardrail-id>
# MODULE7_BEDROCK_GUARDRAIL_VERSION=DRAFT
